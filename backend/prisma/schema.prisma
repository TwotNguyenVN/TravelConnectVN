model trip_expenses {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id            String               @db.Uuid
  title              String
  amount             Decimal              @db.Decimal(12, 2)
  currency_code      String               @default("VND") @db.Char(3)
  paid_by_user_id    String               @db.Uuid
  created_by_user_id String               @db.Uuid
  expense_date       DateTime             @db.Date
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)

  companion_posts    companion_posts      @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payer              public_users         @relation("paid_expenses", fields: [paid_by_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  creator            public_users         @relation("created_expenses", fields: [created_by_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  splits             trip_expense_splits[]

  @@schema("public")
}

model trip_expense_splits {
  expense_id             String            @db.Uuid
  user_id                String            @db.Uuid
  amount                 Decimal           @db.Decimal(12, 2)
  status                 String            @default("pending")
  settled_at             DateTime?         @db.Timestamptz(6)

  expense                trip_expenses     @relation(fields: [expense_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                   public_users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([expense_id, user_id])
  @@schema("public")
}
