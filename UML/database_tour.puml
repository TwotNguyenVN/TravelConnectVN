@startuml database_tour
!theme plain
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor White
    ArrowColor #333333
    BorderColor #555555
}

package "Phân hệ Quản lý Tour du lịch" {

    entity "tours" as tours {
        *id : uuid <<PK>>
        --
        guide_profile_id : uuid <<FK>>
        category_id : bigint <<FK>>
        title : varchar
        province : varchar
        price : decimal
        max_participants : int
        business_status : varchar
        visibility_status : varchar
        duration : varchar
        num_days : int
        num_nights : int
        ...
    }

    entity "tour_categories" as categories {
        *id : bigint <<PK>>
        --
        name : varchar <<Unique>>
        description : text
    }

    entity "tour_images" as images {
        *id : uuid <<PK>>
        --
        tour_id : uuid <<FK>>
        image_url : varchar
        is_cover : boolean
        sort_order : int
    }

    entity "tour_locations" as locations {
        *id : uuid <<PK>>
        --
        tour_id : uuid <<FK>>
        sequence_no : int
        location_name : varchar
        latitude : decimal
        longitude : decimal
        visit_time : timestamptz
        has_breakfast : boolean
        has_lunch : boolean
        has_dinner : boolean
    }

    entity "tour_schedules" as schedules {
        *id : uuid <<PK>>
        --
        tour_id : uuid <<FK>>
        start_date : timestamptz
        price : decimal
        max_participants : int
        status : varchar
    }

    entity "tour_destinations" as destinations {
        *id : uuid <<PK>>
        --
        tour_id : uuid <<FK>>
        sequence_no : int
        name : varchar
        google_maps_link : varchar
    }

    entity "tour_accommodations" as tour_acc {
        *tour_id : uuid <<PK, FK>>
        *accommodation_id : uuid <<PK, FK>>
        --
        check_in_date : date
        check_out_date : date
    }

    entity "partner_accommodations" as partners {
        *id : uuid <<PK>>
        --
        name : varchar
        accommodation_type : varchar
        address : varchar
        province : varchar
    }

    entity "favorite_tours" as favorites {
        *user_id : uuid <<PK, FK>>
        *tour_id : uuid <<PK, FK>>
    }
}

' Relationships
tours ||--o{ images : "contains"
categories ||--o{ tours : "categorizes"
tours ||--o{ locations : "includes itinerary"
tours ||--o{ schedules : "has departures"
tours ||--o{ destinations : "visits"
tours ||--o{ tour_acc : "uses"
partners ||--o{ tour_acc : "provides"
tours ||--o{ favorites : "is liked by"

@enduml
