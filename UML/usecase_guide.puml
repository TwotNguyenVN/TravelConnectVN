@startuml usecase_guide
' ============================================================
' Hình 3.3. Sơ đồ Use Case phân hệ Hướng dẫn viên
' Chi tiết các chức năng dành riêng cho vai trò Guide
' ============================================================

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam usecase {
  BackgroundColor #FEFEFE
  BorderColor #555555
  ArrowColor #333333
}
skinparam package {
  BackgroundColor #F5F5F5
  BorderColor #AAAAAA
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #336699
}

actor "Hướng dẫn viên" as Guide
actor "Quản trị viên" as Admin

rectangle "Phân hệ Hướng dẫn viên" {

  package "Hồ sơ & Xác minh" {
    usecase "Quản lý hồ sơ\nhướng dẫn viên" as UC1
    usecase "Gửi hồ sơ xác minh\n(CCCD, bằng cấp)" as UC2
    usecase "Phê duyệt hồ sơ\nxác minh" as UC3
  }

  package "Quản lý Tour & Đơn hàng" {
    usecase "Đăng tải tour mới" as UC4
    usecase "Quản lý danh sách tour" as UC5
    usecase "Theo dõi danh sách\nkhách đặt (Đã thanh toán)" as UC6
    usecase "Quản lý lịch khởi hành" as UC7
    usecase "Soạn lịch trình\ntheo ngày" as UC8
    usecase "Quản lý thư viện ảnh" as UC9
  }
}

' --- Guide ---
Guide --> UC1
Guide --> UC2
Guide --> UC4
Guide --> UC5
Guide --> UC6
Guide --> UC7
Guide --> UC8
Guide --> UC9

' --- Admin (chỉ phê duyệt) ---
Admin --> UC3

' --- Relationships ---
UC4 ..> UC1 : <<include>>
UC8 ..> UC4 : <<extend>>
UC9 ..> UC4 : <<extend>>
UC7 ..> UC4 : <<extend>>
UC3 ..> UC2 : <<include>>

note right of UC7
  Trạng thái tour:
  Draft → Published → Closed → Completed
end note

note right of UC2
  Upload tài liệu:
  • CCCD / Hộ chiếu
  • Bằng cấp / Chứng chỉ
  Lưu trữ Supabase Storage
end note

@enduml
