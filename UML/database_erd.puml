@startuml database_erd
!theme plain
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor White
    ArrowColor #333333
    BorderColor #555555
}

package "User & Auth" {
    entity "users" as users {
        *id : uuid <<PK>>
        --
        email : varchar
        full_name : varchar
        phone : varchar
        status : varchar
        home_province_id : bigint <<FK>>
        ...
    }

    entity "roles" as roles {
        *role_code : varchar <<PK>>
        --
        description : varchar
    }

    entity "user_roles" as user_roles {
        *user_id : uuid <<PK, FK>>
        *role_code : varchar <<PK, FK>>
    }

    entity "provinces" as provinces {
        *id : bigint <<PK>>
        --
        name : varchar
        region : varchar
    }
}

package "Guide" {
    entity "guide_profiles" as guide_profiles {
        *id : uuid <<PK>>
        --
        user_id : uuid <<FK, Unique>>
        working_area : varchar
        verification_status : varchar
        visibility_status : varchar
        ...
    }

    entity "guide_verification_requests" as guide_verification_requests {
        *id : uuid <<PK>>
        --
        guide_profile_id : uuid <<FK>>
        status : varchar
        ...
    }
}

package "Tour" {
    entity "tours" as tours {
        *id : uuid <<PK>>
        --
        guide_profile_id : uuid <<FK>>
        category_id : bigint <<FK>>
        title : varchar
        province : varchar
        price : decimal
        business_status : varchar
        ...
    }

    entity "tour_schedules" as tour_schedules {
        *id : uuid <<PK>>
        --
        tour_id : uuid <<FK>>
        start_date : timestamptz
        price : decimal
        status : varchar
    }

    entity "tour_categories" as tour_categories {
        *id : bigint <<PK>>
        --
        name : varchar
    }
}

package "Companion" {
    entity "companion_posts" as companion_posts {
        *id : uuid <<PK>>
        --
        user_id : uuid <<FK>>
        title : varchar
        destination : varchar
        business_status : varchar
    }

    entity "companion_requests" as companion_requests {
        *id : uuid <<PK>>
        --
        post_id : uuid <<FK>>
        user_id : uuid <<FK>>
        status : varchar
    }
}

package "Booking & Payment" {
    entity "tour_requests" as tour_requests {
        *id : uuid <<PK>>
        --
        tour_id : uuid <<FK>>
        user_id : uuid <<FK>>
        schedule_id : uuid <<FK>>
        status : varchar
        participant_count : int
    }

    entity "payment_transactions" as payment_transactions {
        *id : uuid <<PK>>
        --
        tour_request_id : uuid <<FK>>
        user_id : uuid <<FK>>
        amount : decimal
        status : varchar
        transaction_code : varchar
    }
}

package "Interaction" {
    entity "conversations" as conversations {
        *id : uuid <<PK>>
        --
        conversation_type : varchar
        related_tour_id : uuid <<FK>>
        related_companion_post_id : uuid <<FK>>
    }

    entity "messages" as messages {
        *id : uuid <<PK>>
        --
        conversation_id : uuid <<FK>>
        sender_user_id : uuid <<FK>>
        content : text
    }

    entity "tour_reviews" as tour_reviews {
        *id : uuid <<PK>>
        --
        tour_id : uuid <<FK>>
        user_id : uuid <<FK>>
        rating : int
    }
}

' Relationships
users ||--o{ user_roles
roles ||--o{ user_roles
provinces ||--o{ users
users ||--|| guide_profiles
guide_profiles ||--o{ guide_verification_requests
guide_profiles ||--o{ tours
tour_categories ||--o{ tours
tours ||--o{ tour_schedules
tours ||--o{ tour_requests
tour_schedules ||--o{ tour_requests
users ||--o{ tour_requests
tour_requests ||--o{ payment_transactions
users ||--o{ companion_posts
companion_posts ||--o{ companion_requests
users ||--o{ companion_requests
conversations ||--o{ messages
users ||--o{ messages
tours ||--o{ tour_reviews
users ||--o{ tour_reviews

@enduml
