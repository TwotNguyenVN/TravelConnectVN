@startuml
title Luồng Đặt Tour và Thanh toán (VNPAY) - TravelConnectVN

' Cấu hình giao diện
skinparam Style strictuml
skinparam SequenceMessageAlignment center
skinparam NoteBackgroundColor #FEFECE
skinparam NoteBorderColor #A80036

' Định nghĩa các tác nhân
actor "Người dùng" as User #LightBlue
participant "Giao diện (Frontend)" as FE #LightGreen
participant "Máy chủ (Backend)" as BE #LightYellow
database "Cơ sở dữ liệu" as DB #LightSalmon
entity "Cổng VNPAY Sandbox" as VNPAY #Violet

' ==========================================
' GIAI ĐOẠN 1: TẠO ĐƠN ĐẶT TOUR (BOOKING)
' ==========================================
group #Lavender "Bước 1: Khởi tạo đơn hàng"
    User -> FE: Chọn Ngày khởi hành & Số lượng khách
    FE -> BE: Gửi yêu cầu đặt tour (POST /bookings)
    activate BE
    
    BE -> DB: Kiểm tra trạng thái Tour & Số chỗ trống (remainingSlots)
    activate DB
    DB --> BE: Thông tin khả dụng
    deactivate DB
    
    alt Số chỗ không đủ
        BE --> FE: Trả về lỗi: "Số chỗ còn lại không đủ"
        FE -> User: Hiển thị thông báo lỗi
    else Thông tin hợp lệ
        BE -> DB: 1. Tạo bản ghi Booking (Trạng thái: PENDING)\n2. Tạm giữ số chỗ (Update remainingSlots)
        activate DB
        DB --> BE: Trả về Booking ID
        deactivate DB
        BE --> FE: Trả về thông tin đơn hàng vừa tạo
    end
    deactivate BE
end

' ==========================================
' GIAI ĐOẠN 2: THANH TOÁN QUA VNPAY
' ==========================================
group #OldLace "Bước 2: Thực hiện thanh toán"
    User -> FE: Nhấn "Thanh toán qua VNPAY"
    FE -> BE: Yêu cầu tạo URL thanh toán (POST /payments/vnpay)
    activate BE
    BE -> BE: Tạo mã giao dịch & Tính toán chữ ký (Checksum)
    BE --> FE: Trả về VNPAY Payment URL
    deactivate BE
    
    FE -> User: Chuyển hướng người dùng sang VNPAY Sandbox
    User -> VNPAY: Nhập thông tin thẻ thử nghiệm & Xác nhận
    VNPAY -> VNPAY: Xử lý giao dịch
    VNPAY --> User: Hiển thị kết quả thanh toán tại cổng
end

' ==========================================
' GIAI ĐOẠN 3: CẬP NHẬT TRẠNG THÁI
' ==========================================
group #HoneyDew "Bước 3: Hoàn tất & Cập nhật"
    VNPAY -> BE: Gửi kết quả (IPN Callback - Server to Server)
    activate BE
    BE -> BE: Xác minh chữ ký & Kiểm tra số tiền
    BE -> DB: 1. Lưu lịch sử giao dịch\n2. Cập nhật Booking (Trạng thái: PAID)
    BE --> VNPAY: Phản hồi "Confirm Success"
    deactivate BE
    
    VNPAY -> FE: Redirect người dùng về trang Return URL
    FE -> BE: Kiểm tra kết quả giao dịch (GET /payments/verify)
    BE --> FE: Trả về trạng thái "Thành công"
    FE -> User: Hiển thị màn hình "Đặt tour thành công!"
end

@enduml
