@startuml database_booking_payment
!theme plain
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor White
    ArrowColor #333333
    BorderColor #555555
}

package "Phân hệ Đặt Tour & Thanh toán" {

    entity "tour_requests" as requests {
        *id : uuid <<PK>>
        --
        tour_id : uuid <<FK>>
        user_id : uuid <<FK>>
        schedule_id : uuid <<FK>>
        participant_count : int
        status : varchar
        note : text
        response_note : text
        requested_at : timestamptz
        processed_at : timestamptz
        processed_by_user_id : uuid <<FK>>
    }

    entity "payment_transactions" as transactions {
        *id : uuid <<PK>>
        --
        tour_request_id : uuid <<FK>>
        user_id : uuid <<FK>>
        amount : decimal
        currency_code : char(3)
        payment_method : varchar
        status : varchar
        transaction_code : varchar <<Unique>>
        provider_transaction_code : varchar
        gateway_response : json
        paid_at : timestamptz
        created_at : timestamptz
    }

    entity "tours" as tours {
        *id : uuid <<PK>>
        --
        title : varchar
        price : decimal
        guide_profile_id : uuid <<FK>>
    }

    entity "tour_schedules" as schedules {
        *id : uuid <<PK>>
        --
        start_date : timestamptz
        max_participants : int
    }

    entity "users (public.users)" as users {
        *id : uuid <<PK>>
        --
        full_name : varchar
        email : varchar
    }
}

' Relationships
users ||--o{ requests : "makes"
tours ||--o{ requests : "is booked"
schedules ||--o{ requests : "applies to"
requests ||--o{ transactions : "generates"
users ||--o{ transactions : "pays"
users ||--o{ requests : "processed by (Admin/Staff)"

note right of requests
  Trạng thái (Status):
  • pending: Đang chờ
  • payment_pending: Chờ thanh toán
  • paid: Đã thanh toán (Thành công)
  • cancelled_by_user: Khách hủy
  • rejected: HDV từ chối
end note

note right of transactions
  Trạng thái (Status):
  • pending: Đang thực hiện
  • paid: Thành công
  • failed: Thất bại
  • cancelled: Đã hủy
end note

@enduml
