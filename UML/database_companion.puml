@startuml database_companion
!theme plain
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor White
    ArrowColor #333333
    BorderColor #555555
}

package "Phân hệ Bạn đồng hành (Companions)" {

    entity "companion_posts" as posts {
        *id : uuid <<PK>>
        --
        user_id : uuid <<FK>>
        title : varchar
        destination : varchar
        start_date : date
        end_date : date
        budget_estimate : decimal
        content : text
        max_participants : int
        business_status : varchar
        visibility_status : varchar
        cover_url : varchar
        images : text[]
        created_at : timestamptz
    }

    entity "companion_requests" as requests {
        *id : uuid <<PK>>
        --
        post_id : uuid <<FK>>
        user_id : uuid <<FK>>
        status : varchar
        content : text
        participant_count : int
        processed_at : timestamptz
        processed_by_user_id : uuid <<FK>>
        created_at : timestamptz
    }

    entity "users (public.users)" as users {
        *id : uuid <<PK>>
        --
        full_name : varchar
        avatar_url : varchar
    }
}

' Relationships
users ||--o{ posts : "creates"
posts ||--o{ requests : "receives"
users ||--o{ requests : "sends"

note right of posts
  Trạng thái (Business Status):
  • open: Đang tìm bạn
  • closed: Đã đủ người
  • cancelled: Đã hủy
end note

note right of requests
  Trạng thái (Status):
  • pending: Đang chờ duyệt
  • approved: Chấp nhận
  • rejected: Từ chối
end note

@enduml
