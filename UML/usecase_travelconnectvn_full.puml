@startuml usecase_travelconnectvn
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam usecase {
  BackgroundColor #FEFEFE
  BorderColor #555555
  ArrowColor #333333
}
skinparam package {
  BackgroundColor #F5F5F5
  BorderColor #AAAAAA
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #336699
}

actor "Khách truy cập" as Guest
actor "Người dùng /\nKhách du lịch" as User
actor "Hướng dẫn viên" as Guide
actor "Quản trị viên" as Admin
actor "Nhân sự kiểm duyệt /\nHỗ trợ" as Staff

' === Actor Generalization ===
User -|> Guest
Guide -|> User

rectangle "Hệ thống TravelConnectVN" {

  package "Tài khoản và bảo mật" {
    usecase "Đăng ký tài khoản" as UC1
    usecase "Đăng nhập đa phương thức" as UC2
    usecase "Quản lý mật khẩu & OTP" as UC3
    usecase "Quản lý hồ sơ cá nhân" as UC4
    usecase "Đăng ký làm Hướng dẫn viên" as UC36
    usecase "Phân quyền người dùng" as UC5
  }

  package "Tour du lịch" {
    usecase "Xem danh sách &\nTìm kiếm tour" as UC6
    usecase "Xem chi tiết &\nBản đồ lộ trình" as UC8
    usecase "Đặt tour (Booking)" as UC10
    usecase "Thanh toán trực tuyến\n(VNPAY)" as UC11
    usecase "Quản lý Booking &\nGiao dịch" as UC35
  }

  package "Hướng dẫn viên" as pkg_guide {
    usecase "Dashboard thống kê\n(HDV)" as UC39
    usecase "Quản lý hồ sơ\nhướng dẫn viên" as UC12
    usecase "Gửi hồ sơ xác minh" as UC13
    usecase "Quản lý Tour\n(Tạo/Sửa/Xoá)" as UC14
    usecase "Soạn lịch trình &\nthư viện ảnh" as UC15
    usecase "Duyệt khách đặt tour" as UC16
  }

  package "Bạn đồng hành" {
    usecase "Xem bài tìm bạn\nđồng hành" as UC17
    usecase "Tạo/Sửa bài tìm bạn" as UC18
    usecase "Quản lý bài đăng\n(Đóng/Mở)" as UC37
    usecase "Gửi yêu cầu tham gia" as UC19
    usecase "Duyệt yêu cầu\ntham gia" as UC20
  }

  package "Tương tác và tiện ích" {
    usecase "Chat realtime\n(1-1 & Nhóm)" as UC21
    usecase "Đánh giá Tour & HDV" as UC22
    usecase "Quản lý Yêu thích" as UC23
    usecase "Nhận thông báo\nrealtime" as UC24
    usecase "Gửi báo cáo vi phạm" as UC25
    usecase "Trợ lý AI tư vấn\ndu lịch" as UC26
    usecase "Nhận gợi ý\ncá nhân hóa" as UC38
  }

  package "Quản trị hệ thống" {
    usecase "Dashboard tổng quan" as UC27
    usecase "Quản trị tài khoản\nngười dùng" as UC28
    usecase "Kiểm duyệt Tour" as UC29
    usecase "Kiểm duyệt bài\nđồng hành" as UC30
    usecase "Xử lý báo cáo\nvi phạm" as UC31
    usecase "Quản lý đánh giá" as UC32
    usecase "Phê duyệt hồ sơ HDV" as UC33
    usecase "Xem nhật ký\nhệ thống" as UC34
  }
}

' ============================================================
' ACTOR → USE CASE ASSOCIATIONS
' ============================================================

' --- Guest (chưa đăng nhập) ---
Guest --> UC1
Guest --> UC2
Guest --> UC6
Guest --> UC8
Guest --> UC17

' --- User (kế thừa Guest, chỉ liệt kê quyền riêng) ---
User --> UC3
User --> UC4
User --> UC36
User --> UC10
User --> UC11
User --> UC35
User --> UC18
User --> UC37
User --> UC19
User --> UC20
User --> UC21
User --> UC22
User --> UC23
User --> UC24
User --> UC25
User --> UC26
User --> UC38

' --- Guide (kế thừa User, chỉ liệt kê quyền riêng) ---
Guide --> UC39
Guide --> UC12
Guide --> UC13
Guide --> UC14
Guide --> UC15
Guide --> UC16

' --- Admin ---
Admin --> UC5
Admin --> UC27
Admin --> UC28
Admin --> UC29
Admin --> UC30
Admin --> UC31
Admin --> UC32
Admin --> UC33
Admin --> UC34

' --- Staff / Moderator ---
Staff --> UC29
Staff --> UC30
Staff --> UC31
Staff --> UC32
Staff --> UC34

' ============================================================
' INCLUDE & EXTEND RELATIONSHIPS
' ============================================================

' Đặt tour yêu cầu đăng nhập trước
UC10 ..> UC2 : <<include>>

' Thanh toán mở rộng từ Đặt tour (không bắt buộc — có thể đặt cọc hoặc full)
UC11 ..> UC10 : <<extend>>

' Quản lý Tour bắt buộc phải có Hồ sơ HDV
UC14 ..> UC12 : <<include>>

' Soạn lịch trình là phần mở rộng của Quản lý Tour
UC15 ..> UC14 : <<extend>>

' Duyệt khách là phần mở rộng của Quản lý Tour
UC16 ..> UC14 : <<extend>>

' Admin phê duyệt dựa trên hồ sơ xác minh đã gửi
UC33 ..> UC13 : <<include>>

' ============================================================
' NOTES
' ============================================================

note right of UC11
  Hỗ trợ 2 hình thức:
  • Thanh toán toàn bộ (Full)
  • Đặt cọc (Deposit)
  VNPAY Sandbox + IPN callback
end note

note right of UC26
  Tích hợp Google Gemini
  Tư vấn theo vai trò:
  User / Guide / Admin
end note

note right of UC21
  WebSocket (Socket.io)
  Chat 1-1 & nhóm đồng hành
  Tự động đồng bộ thành viên
end note

@enduml
