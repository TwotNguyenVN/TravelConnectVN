@startuml
title Luồng Gửi và Xử lý Báo cáo Vi phạm - TravelConnectVN

' Cấu hình giao diện
skinparam Style strictuml
skinparam SequenceMessageAlignment center
skinparam NoteBackgroundColor #FEFECE
skinparam NoteBorderColor #A80036

' Định nghĩa các tác nhân
actor "Người dùng" as User #LightBlue
actor "Quản trị viên (Admin)" as Admin #LightSalmon
participant "Giao diện (Frontend)" as FE #LightGreen
participant "Máy chủ (Backend)" as BE #LightYellow
database "Cơ sở dữ liệu" as DB #LightSalmon

' ==========================================
' GIAI ĐOẠN 1: GỬI BÁO CÁO
' ==========================================
group #Lavender "Bước 1: Báo cáo vi phạm"
    User -> FE: Phát hiện vi phạm (Tour/Bài đăng/User...)\nNhấn "Báo cáo"
    FE -> User: Hiển thị Modal báo cáo (Lý do, Mô tả)
    User -> FE: Nhập thông tin & Gửi
    FE -> BE: POST /reports
    activate BE
    BE -> DB: Lưu báo cáo (Trạng thái: PENDING)
    activate DB
    DB --> BE: Thành công
    deactivate DB
    BE --> FE: Trả về: "Đã gửi báo cáo thành công"
    deactivate BE
    FE -> User: Thông báo cảm ơn & Đóng Modal
end

' ==========================================
' GIAI ĐOẠN 2: QUẢN TRỊ VIÊN XỬ LÝ
' ==========================================
group #OldLace "Bước 2: Xem xét & Xử lý báo cáo"
    Admin -> FE: Truy cập Admin Area > "Quản lý Báo cáo"
    FE -> BE: Lấy danh sách báo cáo (GET /admin/reports)
    activate BE
    BE -> DB: SELECT * FROM reports WHERE status = 'pending'
    activate DB
    DB --> BE: Danh sách báo cáo chi tiết
    deactivate DB
    BE --> FE: Hiển thị danh sách báo cáo
    deactivate BE
    
    Admin -> FE: Xem chi tiết nội dung bị báo cáo & Đưa ra quyết định
    FE -> BE: Gửi kết quả xử lý (PATCH /admin/reports/:id)
    activate BE
    
    group #Pink "Hành động theo mức độ vi phạm"
        BE -> DB: 1. Cập nhật trạng thái báo cáo (RESOLVED / REJECTED)
        BE -> DB: 2. Lưu lịch sử xử lý (report_processing_history)
        BE -> DB: 3. Thực hiện thao tác kỷ luật (Ẩn Tour / Khóa User / Cảnh báo)
        BE -> DB: 4. Ghi nhật ký quản trị (admin_activity_logs)
    end
    
    DB --> BE: Thành công
    BE --> FE: Trả về: "Đã xử lý báo cáo thành công"
    deactivate BE
    FE -> Admin: Cập nhật giao diện danh sách
end

note over User, Admin
    Quy trình này đảm bảo môi trường TravelConnectVN luôn sạch, 
    an toàn và minh bạch cho mọi thành viên.
end note

@enduml
