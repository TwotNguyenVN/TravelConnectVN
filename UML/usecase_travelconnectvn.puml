@startuml usecase_tongquat
' ============================================================
' Hình 3.1. Sơ đồ Use Case tổng quát hệ thống TravelConnectVN
' Mục tiêu: Nhìn toàn cảnh hệ thống, không đi vào chi tiết
' ============================================================

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam usecase {
  BackgroundColor #FEFEFE
  BorderColor #555555
  ArrowColor #333333
}
skinparam package {
  BackgroundColor #F5F5F5
  BorderColor #AAAAAA
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #336699
}

actor "Khách truy cập" as Guest
actor "Người dùng /\nKhách du lịch" as User
actor "Hướng dẫn viên" as Guide
actor "Quản trị viên" as Admin
actor "Nhân sự kiểm duyệt /\nHỗ trợ" as Staff

User -|> Guest
Guide -|> User

rectangle "Hệ thống TravelConnectVN" {

  package "Tài khoản và bảo mật" {
    usecase "Đăng ký / Đăng nhập" as UC_AUTH
    usecase "Quản lý hồ sơ cá nhân" as UC_PROFILE
  }

  package "Tour du lịch" {
    usecase "Xem tour" as UC_VIEW_TOUR
    usecase "Đặt tour" as UC_BOOK
    usecase "Thanh toán" as UC_PAY
    usecase "Quản lý booking" as UC_MANAGE_BOOK
  }

  package "Hướng dẫn viên" {
    usecase "Quản lý hồ sơ HDV" as UC_GUIDE_PROFILE
    usecase "Quản lý tour" as UC_MANAGE_TOUR
    usecase "Theo dõi khách đặt tour" as UC_MANAGE_GUESTS
  }

  package "Bạn đồng hành" {
    usecase "Xem bài đồng hành" as UC_VIEW_COMP
    usecase "Tạo bài đồng hành" as UC_CREATE_COMP
    usecase "Gửi / Duyệt yêu cầu\ntham gia" as UC_JOIN_COMP
  }

  package "Tương tác" {
    usecase "Chat realtime" as UC_CHAT
    usecase "Đánh giá" as UC_REVIEW
    usecase "Báo cáo vi phạm" as UC_REPORT
    usecase "Trợ lý AI" as UC_AI
  }

  package "Quản trị hệ thống" {
    usecase "Quản trị người dùng" as UC_ADMIN_USER
    usecase "Kiểm duyệt nội dung" as UC_MODERATE
    usecase "Phê duyệt hồ sơ HDV" as UC_VERIFY_GUIDE
    usecase "Xem nhật ký hệ thống" as UC_LOG
  }
}

' --- Guest ---
Guest --> UC_AUTH
Guest --> UC_VIEW_TOUR
Guest --> UC_VIEW_COMP

' --- User (kế thừa Guest) ---
User --> UC_PROFILE
User --> UC_BOOK
User --> UC_PAY
User --> UC_MANAGE_BOOK
User --> UC_CREATE_COMP
User --> UC_JOIN_COMP
User --> UC_CHAT
User --> UC_REVIEW
User --> UC_REPORT
User --> UC_AI

' --- Guide (kế thừa User) ---
Guide --> UC_GUIDE_PROFILE
Guide --> UC_MANAGE_TOUR
Guide --> UC_MANAGE_GUESTS

' --- Admin ---
Admin --> UC_ADMIN_USER
Admin --> UC_MODERATE
Admin --> UC_VERIFY_GUIDE
Admin --> UC_LOG

' --- Staff ---
Staff --> UC_MODERATE
Staff --> UC_LOG

' --- Relationships ---
UC_BOOK ..> UC_AUTH : <<include>>
UC_PAY ..> UC_BOOK : <<include>>
note bottom of UC_PAY
  Xác nhận tự động (Paid)
  sau khi chuyển khoản thành công
end note

@enduml
